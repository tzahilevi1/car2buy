# ============================================================
#  Car2Buy — משתני סביבה / סודות (Supabase)
#  הקובץ הזה מקומי בלבד ולא עולה ל-git (מוגן ב-.gitignore).
#  מלא את הערכים אחרי סימן ה-= (בלי מרכאות, בלי רווחים).
# ============================================================

# ---------- ציבורי (בטוח — נכנס לקוד האתר, מוגן ב-RLS) ----------
# Supabase → Settings → API → "Project URL"
#   דוגמה: https://abcdef.supabase.co
SUPABASE_URL=

# Supabase → Settings → API → "Project API keys" → anon / public
#   מחרוזת ארוכה שמתחילה ב-eyJ...
SUPABASE_ANON_KEY=


# ---------- סודי (אסור שיגיע לאתר / ל-git לעולם!) ----------
# רק לשימוש צד-שרת עתידי (Edge Functions / התראות מייל). לא חובה עכשיו.

# Supabase → Settings → API → "service_role" (secret) — הרשאות מלאות, מסוכן
SUPABASE_SERVICE_ROLE_KEY=

# סיסמת הדאטהבייס (Supabase → Settings → Database → Connection string / Password)
SUPABASE_DB_PASSWORD=

# מזהה הפרויקט (Supabase → Settings → General → "Reference ID"), אופציונלי
SUPABASE_PROJECT_REF=
